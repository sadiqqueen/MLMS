# MongoDB connection string (required) — e.g. mongodb://localhost:27017/mtms
# or a MongoDB Atlas URI. Never commit the real value.
MONGO_URI=

# JWT signing secrets (required)
JWT_SECRET=
JWT_REFRESH_SECRET=

# Anthropic API key — powers the consultant-memo Arabic→English translation
# endpoint (/api/consultant-memo/translate). Without it that endpoint returns
# 503 and the UI shows "translation unavailable"; everything else still works.
ANTHROPIC_API_KEY=

# Server port (optional, defaults to 5000)
PORT=5000

# Scheduled data snapshots (weekly/monthly/yearly CSV exports under
# uploads/snapshots). Off by default; set to 'true' to enable the cron jobs
# (see backend/jobs/snapshots.js). Only enable on a single persistent instance.
SNAPSHOTS_ENABLED=false
