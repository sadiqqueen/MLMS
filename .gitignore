# Dependencies
node_modules/
backend/node_modules/
frontend/node_modules/

# Environment and local secrets
.env
.env.*
!.env.example
backend/.env
backend/.env.*
frontend/.env
frontend/.env.*

# Keys, certificates and other credentials
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
id_rsa
id_rsa.*
*.keystore
secrets.json
*.secrets.json

# Generated builds and caches
dist/
frontend/dist/
backend/dist/
.vite/
.cache/
.parcel-cache/
coverage/

# Runtime uploads and logs
uploads/*
backend/uploads/*
!uploads/.gitkeep
!backend/uploads/.gitkeep

# Mobile app APK (large binary — hosted on the VPS, never committed)
frontend/public/app/*.apk
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local/test artifacts
*.cookies
*cookies*.txt
*login*.json
screenshots/
*.screenshot.*
*.tmp
*.temp
*.bak
.DS_Store
Thumbs.db

# Local tool state
.claude/settings.local.json

MTMS_demo_accounts_by_specialty.docx

# Bulk-import credentials manifest (contains shared initial password) — never commit
backend/migrations/data/*credentials*.csv
